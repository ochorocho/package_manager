.idea
node_modules/
playwright-report/
test-results/

# The TYPO3 dev sandbox is generated by .ddev/scripts/setup-typo3.sh.
# Only the manifest + tool configs are tracked so CI can bootstrap from
# a fresh clone.
Build/*
!Build/composer.json
!Build/composer.lock
!Build/phpstan.neon
!Build/phpstan-baseline.neon
!Build/.php-cs-fixer.dist.php