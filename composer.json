{
    "name": "ochorocho/package-manager",
    "type": "typo3-cms-extension",
    "description": "Composer-based TYPO3 extension manager with Packagist integration",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Jochen Roth",
            "email": "rothjochen@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^14.0",
        "typo3/cms-backend": "^14.0",
        "typo3/cms-fluid": "^14.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "typo3/coding-standards": "^0.8",
        "typo3/testing-framework": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Ochorocho\\PackageManager\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ochorocho\\PackageManager\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "package_manager"
        }
    },
    "scripts": {
        "ci:php:stan": "phpstan analyse --no-progress",
        "ci:php:cs": "php-cs-fixer fix --dry-run --diff",
        "fix:php:cs": "php-cs-fixer fix"
    }
}
